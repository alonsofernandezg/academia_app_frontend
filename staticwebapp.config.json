{
  "routes": [
    {
      "route": "/*.html",
      "serve": "/*.html",
      "statusCode": 200
    },
    {
      "route": "/api/*",
      "allowedRoles": [],
      "rewrite": ""
    },
    {
      "route": "/**",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "*.{css,scss,js,png,jpg,jpeg,svg,gif,ico,webp}",
      "*.json"
    ]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".woff": "font/woff",
    ".woff2": "font/woff2"
  },
  "auth": {
    "fileServeConfigurations": []
  }
}
